{
    "id": "beantracker",
    "realm": "beantracker",
    "displayName": "BeanTracker",
    "enabled": true,
    "sslRequired": "external",
    "registrationAllowed": false,
    "loginWithEmailAllowed": true,
    "duplicateEmailsAllowed": false,
    "resetPasswordAllowed": true,
    "editUsernameAllowed": false,
    "bruteForceProtected": true,
    "roles": {
        "realm": [
            {
                "name": "customer",
                "description": "End customer who books tickets"
            },
            {
                "name": "clerk",
                "description": "Counter clerk who serves customers"
            },
            {
                "name": "admin",
                "description": "System administrator"
            }
        ]
    },
    "clients": [
        {
            "clientId": "beantracker-api",
            "name": "BeanTracker API",
            "enabled": true,
            "publicClient": true,
            "standardFlowEnabled": true,
            "directAccessGrantsEnabled": false,
            "redirectUris": [
                "https://localhost:7157/scalar/*",
                "http://localhost:5255/scalar/*"
            ],
            "webOrigins": [
                "https://localhost:7157",
                "http://localhost:5255"
            ],
            "defaultClientScopes": [
                "openid",
                "profile",
                "email",
                "roles"
            ],
            "protocolMappers": [
                {
                    "name": "realm roles",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-realm-role-mapper",
                    "config": {
                        "claim.name": "roles",
                        "jsonType.label": "String",
                        "multivalued": "true",
                        "userinfo.token.claim": "true",
                        "id.token.claim": "true",
                        "access.token.claim": "true"
                    }
                },
                {
                    "name": "teleq-api audience",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-audience-mapper",
                    "config": {
                        "included.client.audience": "teleq-api",
                        "id.token.claim": "false",
                        "access.token.claim": "true"
                    }
                }
            ]
        },
        {
            "clientId": "beantracker-web",
            "name": "BeanTracker Web",
            "enabled": true,
            "publicClient": true,
            "standardFlowEnabled": true,
            "directAccessGrantsEnabled": false,
            "redirectUris": [
                "https://localhost:7243/signin-oidc",
                "http://localhost:5086/signin-oidc"
            ],
            "webOrigins": [
                "https://localhost:7243",
                "http://localhost:5086"
            ],
            "defaultClientScopes": [
                "openid",
                "profile",
                "email",
                "roles"
            ],
            "protocolMappers": [
                {
                    "name": "realm roles",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-realm-role-mapper",
                    "config": {
                        "claim.name": "roles",
                        "jsonType.label": "String",
                        "multivalued": "true",
                        "userinfo.token.claim": "true",
                        "id.token.claim": "true",
                        "access.token.claim": "true"
                    }
                },
                {
                    "name": "teleq-api audience",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-audience-mapper",
                    "config": {
                        "included.client.audience": "teleq-api",
                        "id.token.claim": "false",
                        "access.token.claim": "true"
                    }
                }
            ]
        }
        ,
        {
            "clientId": "beantracker-maui",
            "name": "BeanTracker MAUI",
            "enabled": true,
            "publicClient": true,
            "standardFlowEnabled": true,
            "directAccessGrantsEnabled": false,
            "redirectUris": [
                "beantracker://callback",
                "http://127.0.0.1:49152/"
            ],
            "webOrigins": [
                "+"
            ],
            "defaultClientScopes": [
                "openid",
                "profile",
                "email",
                "roles"
            ],
            "protocolMappers": [
                {
                    "name": "realm roles",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-realm-role-mapper",
                    "config": {
                        "claim.name": "roles",
                        "jsonType.label": "String",
                        "multivalued": "true",
                        "userinfo.token.claim": "true",
                        "id.token.claim": "true",
                        "access.token.claim": "true"
                    }
                }
            ]
        }
    ],
    "users": [
        {
            "username": "admin@teleq.local",
            "email": "admin@teleq.local",
            "firstName": "Admin",
            "lastName": "User",
            "enabled": true,
            "credentials": [
                {
                    "type": "password",
                    "value": "admin",
                    "temporary": false
                }
            ],
            "realmRoles": [
                "admin"
            ]
        },
        {
            "username": "clerk@teleq.local",
            "email": "clerk@teleq.local",
            "firstName": "Clerk",
            "lastName": "User",
            "enabled": true,
            "credentials": [
                {
                    "type": "password",
                    "value": "clerk",
                    "temporary": false
                }
            ],
            "realmRoles": [
                "clerk"
            ]
        }
    ]
}