<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeanTracker.MAUI.Features.Coffee.CoffeeDrinkDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BeanTracker.MAUI.Features.Coffee"
    x:DataType="vm:CoffeeDrinkDetailViewModel"
    Title="{Binding SelectedDrink.Name}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label
                Style="{StaticResource Title}"
                Text="{Binding SelectedDrink.Name}" />
            <Label Text="{Binding SelectedDrink.Description}" />
            <Label Text="{Binding SelectedDrink.Origin}" />
            <Button
                Text="{Binding FavouriteLabel}"
                Command="{Binding ToggleFavouriteCommand}" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
