<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeanTracker.MAUI.Features.Coffee.CoffeeDrinkDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BeanTracker.MAUI.Features.Coffee"
    x:DataType="vm:CoffeeDrinkDetailViewModel"
    Title="{Binding SelectedDrink.Name}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Coffee image -->
            <Border HeightRequest="220" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Grid>
                    <Image
                        Source="{Binding ImageUrl}"
                        Aspect="AspectFill"
                        IsVisible="{Binding IsNotLoading}" />
                    <ActivityIndicator
                        IsRunning="{Binding IsLoading}"
                        IsVisible="{Binding IsLoading}"
                        Color="{StaticResource Cappuccino}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <Label
                Style="{StaticResource Title}"
                Text="{Binding SelectedDrink.Name}" />

            <!-- Description -->
            <Grid ColumnDefinitions="36,*" ColumnSpacing="10" RowDefinitions="Auto,Auto">
                <Border
                    BackgroundColor="{StaticResource Cappuccino}"
                    StrokeThickness="0"
                    StrokeShape="Ellipse"
                    HeightRequest="32" WidthRequest="32"
                    HorizontalOptions="Center" VerticalOptions="Start">
                    <Label Text="📝" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="Description" FontSize="11" TextColor="{StaticResource WarmGray400}" FontAttributes="Bold" />
                    <Label Text="{Binding SelectedDrink.Description}" FontSize="14" />
                </VerticalStackLayout>
            </Grid>

            <!-- Origin -->
            <Grid ColumnDefinitions="36,*" ColumnSpacing="10">
                <Border
                    BackgroundColor="{StaticResource Lungo}"
                    StrokeThickness="0"
                    StrokeShape="Ellipse"
                    HeightRequest="32" WidthRequest="32"
                    HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="🌍" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="Origin" FontSize="11" TextColor="{StaticResource WarmGray400}" FontAttributes="Bold" />
                    <Label Text="{Binding SelectedDrink.Origin}" FontSize="14" />
                </VerticalStackLayout>
            </Grid>

            <!-- Flavor Notes -->
            <Grid ColumnDefinitions="36,*" ColumnSpacing="10">
                <Border
                    BackgroundColor="{StaticResource Mocha}"
                    StrokeThickness="0"
                    StrokeShape="Ellipse"
                    HeightRequest="32" WidthRequest="32"
                    HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="🍫" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="Flavor Notes" FontSize="11" TextColor="{StaticResource WarmGray400}" FontAttributes="Bold" />
                    <Label Text="{Binding FlavorNotesText}" FontSize="14" />
                </VerticalStackLayout>
            </Grid>

            <Button
                Text="{Binding FavouriteLabel}"
                Command="{Binding ToggleFavouriteCommand}"
                BackgroundColor="{StaticResource WarmGray200}"
                TextColor="{StaticResource Espresso}"
                CornerRadius="24"
                Margin="0,8,0,0">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsFavourite}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource Macchiato}" />
                        <Setter Property="TextColor" Value="{StaticResource FlatWhite}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
