<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeanTracker.MAUI.Features.Coffee.CoffeeDrinksPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BeanTracker.MAUI.Features.Coffee"
    xmlns:core="clr-namespace:BeanTracker.Core.Coffee;assembly=BeanTracker.Core"
    x:DataType="vm:CoffeeDrinksViewModel"
    Title="Coffee Drinks">

    <Grid RowDefinitions="Auto,*">
        <SearchBar
            Grid.Row="0"
            Placeholder="Search drinks…"
            Text="{Binding SearchQuery}"
            SearchCommand="{Binding SearchCommand}" />

        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding Drinks}">
            <CollectionView.EmptyView>
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Text="No drinks found." />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="core:CoffeeDrink">
                    <Grid ColumnDefinitions="64,*" Padding="16,10">
                        <Border
                            BackgroundColor="{StaticResource Cappuccino}"
                            StrokeThickness="0"
                            StrokeShape="Ellipse"
                            HeightRequest="42" WidthRequest="42"
                            HorizontalOptions="Center" VerticalOptions="Center">
                            <Label
                                Text="☕"
                                FontSize="22"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout
                            Grid.Column="1"
                            VerticalOptions="Center"
                            Spacing="2">
                            <Label
                                Text="{Binding Name}"
                                FontSize="15"
                                FontAttributes="Bold" />
                            <Label
                                Text="{Binding Origin}"
                                FontSize="12"
                                TextColor="{StaticResource WarmGray400}" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
