<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeanTracker.MAUI.Features.Coffee.CoffeeDrinksPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BeanTracker.MAUI.Features.Coffee"
    xmlns:core="clr-namespace:BeanTracker.Core.Coffee;assembly=BeanTracker.Core"
    x:DataType="vm:CoffeeDrinksViewModel"
    Title="Coffee Drinks">

    <Grid RowDefinitions="Auto,*">
        <SearchBar
            Grid.Row="0"
            Placeholder="Search drinks…"
            Text="{Binding SearchQuery}"
            SearchCommand="{Binding SearchCommand}" />

        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding Drinks}">
            <CollectionView.EmptyView>
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Text="No drinks found." />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="core:CoffeeDrink">
                    <Label Text="{Binding Name}" Padding="16,12" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
