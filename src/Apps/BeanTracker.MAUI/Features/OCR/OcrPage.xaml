<?xml version="1.0" encoding="utf-8" ?>
<host:FeatureView xmlns:host="clr-namespace:BeanTracker.MAUI.Features.Host"
    x:Class="BeanTracker.MAUI.Features.OCR.OcrPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BeanTracker.MAUI.Features.OCR"
    x:DataType="vm:OcrViewModel">

    <ScrollView x:Name="PageScrollView">
        <VerticalStackLayout Spacing="20" Padding="16">

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    Text="📷 Take Photo"
                    Command="{Binding TakePhotoCommand}" />
                <Button
                    Grid.Column="1"
                    Text="📁 Upload File"
                    Command="{Binding UploadFileCommand}" />
            </Grid>

            <!-- Empty State -->
            <VerticalStackLayout
                IsVisible="{Binding HasNoImage}"
                Spacing="12"
                HorizontalOptions="Center"
                Padding="0,48">
                <Label
                    Text="🔍"
                    FontSize="64"
                    HorizontalOptions="Center" />
                <Label
                    Text="Take a photo or upload a file to begin scanning."
                    HorizontalTextAlignment="Center"
                    TextColor="{StaticResource WarmGray400}"
                    FontSize="14" />
            </VerticalStackLayout>

            <!-- Image Preview -->
            <Border
                IsVisible="{Binding HasImage}"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="1">
                <Image
                    Source="{Binding SelectedImageSource}"
                    Aspect="AspectFit"
                    HeightRequest="320" />
            </Border>

            <!-- File Size — visible only in Debug builds -->
            <Label
                Text="{Binding FileSizeText, StringFormat='File size: {0}'}"
                IsVisible="{Binding ShowFileSizeInfo}"
                HorizontalTextAlignment="Center"
                FontSize="12"
                TextColor="{StaticResource WarmGray400}" />

            <!-- Drink Selector — visible when image is loaded -->
            <VerticalStackLayout IsVisible="{Binding HasImage}" Spacing="8">
                <Label
                    Text="Select drink type to analyze:"
                    FontSize="14"
                    FontAttributes="Bold" />
                <Picker
                    ItemsSource="{Binding AvailableDrinks}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedDrink}" />
            </VerticalStackLayout>

            <!-- Analyze Button -->
            <Button
                Text="🤖 Analyze with AI"
                Command="{Binding AnalyzeImageCommand}"
                IsVisible="{Binding HasImage}"
                IsEnabled="{Binding CanAnalyze}" />

            <!-- Busy Indicator -->
            <ActivityIndicator
                IsRunning="{Binding IsAnalyzing}"
                IsVisible="{Binding IsAnalyzing}"
                HorizontalOptions="Center" />

            <!-- Analysis Result -->
            <Border
                x:Name="AnalysisResultBorder"
                IsVisible="{Binding HasAnalysisResult}"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="1"
                Padding="12">
                <VerticalStackLayout Spacing="6">
                    <Label
                        Text="🧠 AI Analysis"
                        FontAttributes="Bold"
                        FontSize="14" />
                    <Label
                        Text="{Binding AnalysisResult}"
                        FontSize="13"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <!-- Clear Image Button -->
            <Button
                Text="🗑 Clear Image"
                Command="{Binding ClearImageCommand}"
                IsVisible="{Binding HasImage}"
                BackgroundColor="{StaticResource Mocha}"
                TextColor="{StaticResource White}" />

        </VerticalStackLayout>
    </ScrollView>

</host:FeatureView>
