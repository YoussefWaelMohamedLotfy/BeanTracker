<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeanTracker.MAUI.Features.Favourites.FavouritesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BeanTracker.MAUI.Features.Favourites"
    xmlns:core="clr-namespace:BeanTracker.Core.Favourites;assembly=BeanTracker.Core"
    x:DataType="vm:FavouritesViewModel"
    Title="Favourites">

    <CollectionView ItemsSource="{Binding Favourites}">
        <CollectionView.EmptyView>
            <Label
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Text="No favourites saved yet." />
        </CollectionView.EmptyView>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="core:FavouriteDrink">
                <Grid ColumnDefinitions="64,*" Padding="16,10">
                    <Border
                        BackgroundColor="{StaticResource Mocha}"
                        StrokeThickness="0"
                        StrokeShape="Ellipse"
                        HeightRequest="42" WidthRequest="42"
                        HorizontalOptions="Center" VerticalOptions="Center">
                        <Label
                            Text="♥"
                            FontSize="22"
                            TextColor="{StaticResource Crema}"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Border>
                    <Label
                        Grid.Column="1"
                        Text="{Binding DrinkId}"
                        FontSize="15"
                        FontAttributes="Bold"
                        VerticalOptions="Center" />
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
