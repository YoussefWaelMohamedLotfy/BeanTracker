<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeanTracker.MAUI.Features.Favourites.FavouritesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BeanTracker.MAUI.Features.Favourites"
    xmlns:core="clr-namespace:BeanTracker.Core.Favourites;assembly=BeanTracker.Core"
    x:DataType="vm:FavouritesViewModel"
    Title="Favourites">

    <CollectionView ItemsSource="{Binding Favourites}">
        <CollectionView.EmptyView>
            <Label
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Text="No favourites saved yet." />
        </CollectionView.EmptyView>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="core:FavouriteDrink">
                <Label Text="{Binding DrinkId}" Padding="16,12" />
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
