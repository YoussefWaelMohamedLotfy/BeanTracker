<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeanTracker.MAUI.Features.Breweries.BreweryDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BeanTracker.MAUI.Features.Breweries"
    x:DataType="vm:BreweryDetailViewModel"
    Title="{Binding SelectedBrewery.Name}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label
                Style="{StaticResource Title}"
                Text="{Binding SelectedBrewery.Name}" />
            <Label Text="{Binding SelectedBrewery.BreweryType}" />
            <Label Text="{Binding SelectedBrewery.City}" />
            <Label Text="{Binding SelectedBrewery.State}" />
            <Label Text="{Binding SelectedBrewery.Country}" />
            <Label Text="{Binding SelectedBrewery.Phone}" />
            <Label Text="{Binding SelectedBrewery.WebsiteUrl}" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
