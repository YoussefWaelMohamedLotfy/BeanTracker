<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeanTracker.MAUI.Features.Breweries.BreweriesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BeanTracker.MAUI.Features.Breweries"
    xmlns:core="clr-namespace:BeanTracker.Core.Breweries;assembly=BeanTracker.Core"
    x:DataType="vm:BreweriesViewModel"
    Title="Breweries">

    <Grid RowDefinitions="Auto,*">
        <SearchBar
            Grid.Row="0"
            Placeholder="Search breweries…"
            Text="{Binding SearchQuery}"
            SearchCommand="{Binding SearchCommand}" />

        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding Breweries}">
            <CollectionView.EmptyView>
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Text="No breweries found." />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="core:Brewery">
                    <Grid ColumnDefinitions="64,*" Padding="16,10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BreweriesViewModel}}, Path=SelectBreweryCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                        <Border
                            BackgroundColor="{StaticResource Lungo}"
                            StrokeThickness="0"
                            StrokeShape="Ellipse"
                            HeightRequest="42" WidthRequest="42"
                            HorizontalOptions="Center" VerticalOptions="Center">
                            <Label
                                Text="🏭"
                                FontSize="20"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout
                            Grid.Column="1"
                            VerticalOptions="Center"
                            Spacing="2">
                            <Label
                                Text="{Binding Name}"
                                FontSize="15"
                                FontAttributes="Bold" />
                            <Label
                                Text="{Binding City}"
                                FontSize="12"
                                TextColor="{StaticResource WarmGray400}" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
