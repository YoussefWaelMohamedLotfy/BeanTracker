<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeanTracker.MAUI.Features.Breweries.BreweriesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BeanTracker.MAUI.Features.Breweries"
    xmlns:core="clr-namespace:BeanTracker.Core.Breweries;assembly=BeanTracker.Core"
    x:DataType="vm:BreweriesViewModel"
    Title="Breweries">

    <Grid RowDefinitions="Auto,*">
        <SearchBar
            Grid.Row="0"
            Placeholder="Search breweries…"
            Text="{Binding SearchQuery}"
            SearchCommand="{Binding SearchCommand}" />

        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding Breweries}">
            <CollectionView.EmptyView>
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Text="No breweries found." />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="core:Brewery">
                    <Label Text="{Binding Name}" Padding="16,12" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
