<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeanTracker.MAUI.Features.BarcodeScanner.ImageSubmitPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BeanTracker.MAUI.Features.BarcodeScanner"
    x:DataType="vm:ImageSubmitViewModel"
    Title="Submit Image">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="16">

            <!-- Image Preview -->
            <Border
                IsVisible="{Binding HasImage}"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="1">
                <Image
                    Source="{Binding CapturedImage}"
                    Aspect="AspectFit"
                    HeightRequest="280" />
            </Border>

            <!-- No image fallback -->
            <VerticalStackLayout
                IsVisible="{Binding HasNoImage}"
                Spacing="8"
                HorizontalOptions="Center"
                Padding="0,24">
                <Label Text="🖼️" FontSize="56" HorizontalOptions="Center" />
                <Label
                    Text="No image captured."
                    HorizontalTextAlignment="Center"
                    TextColor="{StaticResource WarmGray400}"
                    FontSize="14" />
            </VerticalStackLayout>

            <!-- Title -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Title" FontSize="14" FontAttributes="Bold" />
                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Padding="4,0">
                    <Entry
                        Placeholder="Enter a title…"
                        Text="{Binding Title}"
                        MaxLength="15"
                        IsEnabled="{Binding IsNotSubmitting}" />
                </Border>
                <Grid ColumnDefinitions="*,Auto">
                    <Label
                        Grid.Column="0"
                        Text="{Binding TitleError}"
                        IsVisible="{Binding HasTitleError}"
                        TextColor="Red"
                        FontSize="12" />
                    <Label
                        Grid.Column="1"
                        FontSize="12"
                        TextColor="{StaticResource WarmGray400}"
                        HorizontalTextAlignment="End">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding TitleCharCount}" />
                                <Span Text=" / 15" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Grid>
            </VerticalStackLayout>

            <!-- Description -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Description" FontSize="14" FontAttributes="Bold" />
                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Padding="4,4">
                    <Editor
                        Placeholder="Enter a description…"
                        Text="{Binding Description}"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="100"
                        IsEnabled="{Binding IsNotSubmitting}" />
                </Border>
            </VerticalStackLayout>

            <!-- Submit Button + Indicator -->
            <ActivityIndicator
                IsRunning="{Binding IsSubmitting}"
                IsVisible="{Binding IsSubmitting}"
                HorizontalOptions="Center" />

            <Button
                Text="✅ Submit"
                Command="{Binding SubmitCommand}"
                IsEnabled="{Binding CanSubmit}"
                HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
