<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BeanTracker.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:coffee="clr-namespace:BeanTracker.MAUI.Features.Coffee"
    xmlns:favourites="clr-namespace:BeanTracker.MAUI.Features.Favourites"
    xmlns:breweries="clr-namespace:BeanTracker.MAUI.Features.Breweries"
    Title="BeanTracker">

    <TabBar>
        <Tab Title="Coffee">
            <ShellContent
                ContentTemplate="{DataTemplate coffee:CoffeeDrinksPage}"
                Route="CoffeeDrinks" />
        </Tab>
        <Tab Title="Favourites">
            <ShellContent
                ContentTemplate="{DataTemplate favourites:FavouritesPage}"
                Route="Favourites" />
        </Tab>
        <Tab Title="Breweries">
            <ShellContent
                ContentTemplate="{DataTemplate breweries:BreweriesPage}"
                Route="Breweries" />
        </Tab>
    </TabBar>

</Shell>
